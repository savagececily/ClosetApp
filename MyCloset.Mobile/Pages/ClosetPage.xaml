<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCloset.Mobile.ViewModels"
             x:Class="MyCloset.Mobile.Pages.ClosetPage"
             Title="My Closet">
    
    <ContentPage.BindingContext>
        <vm:ClosetViewModel />
    </ContentPage.BindingContext>

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Add Item" Command="{Binding AddItemCommand}" IconImageSource="plus_icon.png" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        
        <!-- Search Bar -->
        <SearchBar Grid.Row="0" 
                   Placeholder="Search clothing items..." 
                   Text="{Binding SearchText}" 
                   Margin="10" />

        <!-- Items List -->
        <RefreshView Grid.Row="1" 
                     Command="{Binding LoadItemsCommand}" 
                     IsRefreshing="{Binding IsLoading}">
            <CollectionView ItemsSource="{Binding ClothingItems}" 
                          SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <SwipeView>
                            <SwipeView.RightItems>
                                <SwipeItems>
                                    <SwipeItem Text="AI Analyze" 
                                             BackgroundColor="{StaticResource Primary}"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClosetViewModel}}, Path=AnalyzeItemWithAICommand}"
                                             CommandParameter="{Binding .}" />
                                    <SwipeItem Text="Delete" 
                                             BackgroundColor="Red"
                                             Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ClosetViewModel}}, Path=DeleteItemCommand}"
                                             CommandParameter="{Binding .}" />
                                </SwipeItems>
                            </SwipeView.RightItems>
                            
                            <Frame Margin="10,5" Padding="10" CornerRadius="10" HasShadow="True">
                                <Grid ColumnDefinitions="80,*" ColumnSpacing="15">
                                    <Image Grid.Column="0" 
                                           Source="{Binding LinkToPhoto}" 
                                           Aspect="AspectFill" 
                                           HeightRequest="80" 
                                           WidthRequest="80" />
                                    
                                    <VerticalStackLayout Grid.Column="1" Spacing="5">
                                        <Label Text="{Binding Title}" 
                                               FontSize="18" 
                                               FontAttributes="Bold" />
                                        <Label Text="{Binding Category}" 
                                               TextColor="{StaticResource Gray600}" />
                                        <Label Text="{Binding Color}" 
                                               FontSize="12" />
                                        <Label Text="{Binding Brand}" 
                                               FontSize="12" 
                                               TextColor="{StaticResource Gray500}" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Frame>
                        </SwipeView>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center">
                        <Label Text="No clothing items yet" 
                               FontSize="20" 
                               TextColor="{StaticResource Gray600}" />
                        <Label Text="Tap + to add your first item" 
                               FontSize="14" 
                               TextColor="{StaticResource Gray500}" />
                    </VerticalStackLayout>
                </CollectionView.EmptyView>
            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
