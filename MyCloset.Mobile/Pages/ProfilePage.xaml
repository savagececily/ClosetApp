<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:MyCloset.Mobile.ViewModels"
             x:Class="MyCloset.Mobile.Pages.ProfilePage"
             Title="Profile">
    
    <ContentPage.BindingContext>
        <vm:ProfileViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">
            
            <Frame Padding="0" CornerRadius="60" HeightRequest="120" WidthRequest="120" HorizontalOptions="Center">
                <Image Source="default_profile.png" Aspect="AspectFill" />
            </Frame>

            <Label Text="{Binding FirstName}" 
                   FontSize="24" 
                   FontAttributes="Bold" 
                   HorizontalOptions="Center" />

            <Label Text="{Binding Email}" 
                   FontSize="14" 
                   TextColor="{StaticResource Gray600}" 
                   HorizontalOptions="Center" />

            <!-- Edit Profile Section -->
            <Label Text="Edit Profile" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   Margin="0,20,0,0" />

            <Entry Placeholder="First Name" 
                   Text="{Binding FirstName}" />

            <Entry Placeholder="Last Name" 
                   Text="{Binding LastName}" />

            <Entry Placeholder="Email" 
                   Text="{Binding Email}" 
                   Keyboard="Email" />

            <Button Text="Save Profile" 
                    Command="{Binding SaveProfileCommand}"
                    BackgroundColor="{StaticResource Primary}" 
                    TextColor="White" 
                    HeightRequest="50" />

            <!-- Settings Section -->
            <Label Text="Settings" 
                   FontSize="20" 
                   FontAttributes="Bold" 
                   Margin="0,20,0,0" />

            <Frame Padding="15" CornerRadius="10" HasShadow="True">
                <VerticalStackLayout Spacing="15">
                    <Label Text="App Version: 1.0.0" FontSize="14" />
                    <Label Text="API Endpoint: https://localhost:5001" FontSize="12" TextColor="{StaticResource Gray600}" />
                </VerticalStackLayout>
            </Frame>

            <Button Text="Logout" 
                    Command="{Binding LogoutCommand}"
                    BackgroundColor="Red" 
                    TextColor="White" 
                    HeightRequest="50" 
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
